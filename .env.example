# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# AWS (for Nova 2 Pro via Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# Optional: defaults to amazon.nova-premier-v1:0
BEDROCK_MODEL_ID=amazon.nova-premier-v1:0
# Optional: if set, this value is used as modelId (profile ID or ARN)
BEDROCK_INFERENCE_PROFILE_ID=

# App settings
WORKDIR=/tmp/maintainer-workspaces
LOG_LEVEL=INFO
MAX_REPO_SIZE_MB=500
TEST_TIMEOUT_SECONDS=300
